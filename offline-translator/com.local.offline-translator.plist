<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.offline-translator</string>

    <!-- MLX server (Apple Silicon, Metal GPU). 跑在用户 GUI 会话里才能拿到 Metal,
         所以是 LaunchAgent 而非 system LaunchDaemon。 -->
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.local/share/offline-translator/venv/bin/python</string>
        <string>-m</string>
        <string>mlx_lm</string>
        <string>server</string>
        <string>--model</string>
        <string>Hy-MT2-1.8B</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>8110</string>
        <string>--log-level</string>
        <string>WARNING</string>
    </array>

    <!-- 中性 model id "Hy-MT2-1.8B"：实为软链，指向当前量化目录(现 Hy-MT2-1.8B-mlx-8bit)。
         相对 --model + WorkingDirectory 让注册 id 干净、跨机器通用；与量化解耦——
         以后换 4bit/8bit 只改软链指向，客户端(Bob/扩展)的 model 字段不用动。 -->
    <key>WorkingDirectory</key>
    <string>__HOME__/.local/share/offline-translator</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/tmp/offline-translator.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/offline-translator.err.log</string>
</dict>
</plist>
