<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.local.offline-translator</string>

    <!-- MLX server (Apple Silicon, Metal GPU). 跑在用户 GUI 会话里才能拿到 Metal,
         所以是 LaunchAgent 而非 system LaunchDaemon。 -->
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.local/share/offline-translator/venv/bin/python</string>
        <string>-m</string>
        <string>mlx_lm</string>
        <string>server</string>
        <string>--model</string>
        <string>__HOME__/.local/share/offline-translator/Hy-MT2-1.8B-mlx-4bit</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>8110</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/tmp/offline-translator.out.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/offline-translator.err.log</string>
</dict>
</plist>
